{
  "name": "personal-finance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @personal-finance/server --filter @personal-finance/web dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "biome lint --error-on-warnings .",
    "test": "pnpm -r test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "validate:private-imports": "pnpm --filter @personal-finance/server validate:private-imports",
    "verify": "pnpm check && pnpm format:check && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
